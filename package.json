{
  "name": "@sha3/click-collector",
  "version": "0.4.0",
  "private": false,
  "type": "module",
  "main": "./dist/public-api.js",
  "types": "./dist/public-api.d.ts",
  "exports": {
    ".": {
      "types": "./dist/public-api.d.ts",
      "import": "./dist/public-api.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "start": "node --import tsx src/index.ts",
    "build": "node scripts/build-package.mjs",
    "prepack": "npm run build",
    "check": "npm run lint && npm run format:check && npm run typecheck && npm run test",
    "fix": "npm run lint:fix && npm run format:write",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "test": "node scripts/run-tests.mjs",
    "publish": "node scripts/release-publish.mjs"
  },
  "dependencies": {
    "@clickhouse/client": "^1.18.1",
    "@sha3/crypto": "^0.8.0",
    "@sha3/logger": "^2.0.0",
    "@sha3/polymarket": "^0.7.0",
    "dotenv": "^16.6.1"
  },
  "devDependencies": {
    "@sha3/code-standards": "^0.1.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.20.1",
    "prettier": "^3.5.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.56.1"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/sha3dev/click-collector"
  },
  "homepage": "https://github.com/sha3dev/click-collector#readme",
  "bugs": {
    "url": "https://github.com/sha3dev/click-collector/issues"
  },
  "codeStandards": {
    "template": "node-service",
    "profilePath": null,
    "withAiAdapters": true,
    "lastRefreshWith": "0.2.0"
  }
}
